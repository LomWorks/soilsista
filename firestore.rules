rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===== Helper Functions =====
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isValidUser() {
      return isSignedIn() && 
             request.resource.data.userId == request.auth.uid;
    }
    
    // ===== Users Collection =====
    // Users can create their own profile during signup and manage their own data
    match /users/{userId} {
      // Allow user creation during signup (document ID must match auth uid)
      allow create: if request.auth != null && 
                      request.auth.uid == userId &&
                      request.resource.data.userId == request.auth.uid &&
                      request.resource.data.email == request.auth.token.email;
      
      // Users can read and update their own profile
      allow read, update: if isOwner(userId);
      
      // Only allow deletes from the user themselves (optional, can restrict further)
      allow delete: if isOwner(userId);
    }
    
    // ===== Activities Collection =====
    // Used for notifications, consultations, and system messages
    match /activities/{activityId} {
      // Anyone can create activities (for contact forms, new signups, etc.)
      // But must include a userId or be a system message
      allow create: if request.resource.data.userId != null || 
                      request.resource.data.type == "notification";
      
      // Users can read their own activities
      allow read: if isSignedIn() && 
                    (resource.data.userId == request.auth.uid || 
                     !exists(/databases/$(database)/documents/activities/$(activityId)));
      
      // Users can update their own activities (e.g., mark as read)
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      // Users can delete their own activities
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
    
    // ===== Farms Collection =====
    // Individual farms managed by users
    match /farms/{farmId} {
      allow create: if isValidUser();
      allow read, update, delete: if isSignedIn() && 
                                    resource.data.userId == request.auth.uid;
    }
    
    // ===== Crops Collection =====
    // Crops planted/managed by users
    match /crops/{cropId} {
      allow create: if isValidUser();
      allow read, update, delete: if isSignedIn() && 
                                    resource.data.userId == request.auth.uid;
    }
    
    // ===== Tasks Collection =====
    // Daily farming tasks for users
    match /tasks/{taskId} {
      allow create: if isValidUser();
      allow read, update, delete: if isSignedIn() && 
                                    resource.data.userId == request.auth.uid;
    }
    
    // ===== Weather Data Collection =====
    // Populated by Cloud Functions, readable by authenticated users
    match /weather/{locationId} {
      allow read: if isSignedIn();
      // Only Cloud Functions can write weather data
      allow write: if false;
    }
    
    // ===== Consultations Collection =====
    // WhatsApp consultation requests (paid tier)
    match /consultations/{consultationId} {
      allow create: if isValidUser();
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
    
    // ===== Rewards/Gamification Collection =====
    // User rewards and achievements (managed by Cloud Functions)
    match /rewards/{userId} {
      allow read: if isOwner(userId);
      // Only Cloud Functions should write rewards
      allow write: if false;
    }
    
    // ===== Admin Collection (Future) =====
    // Admin-only access for managing consultations, users, etc.
    match /admin/{document=**} {
      // TODO: Add admin role check when admin system is implemented
      allow read, write: if false;
    }
  }
}
